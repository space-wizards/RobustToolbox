<Control xmlns="https://spacestation14.io"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:graphics="clr-namespace:Robust.Client.Graphics"
         xmlns:interface="clr-namespace:Robust.Client.Editor.Interface"
         x:Class="Robust.Client.Editor.Interface.EditorTabPanel"
         MouseFilter="Stop">
    <BoxContainer Orientation="Vertical">
        <!-- Needs MouseFilter="Stop" so that hit detection works when dragging tabs around. -->
        <Control Name="TabsContainer" />
        <Control VerticalExpand="True">
            <PanelContainer StyleClasses="EditorPanelBackground" Name="Content" />
            <interface:EditorTabDropOverlay Name="DropOverlay" Access="PrivateProtected" Visible="False" />
        </Control>
    </BoxContainer>
</Control>
